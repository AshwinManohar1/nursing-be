PORT=8000
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=shiftwise
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-...
OPEN_API_KEY=sk-...

# JWT (RS256) - generate with: uv run python scripts/generate_jwt_keys.py
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Super admin creation secret
SUPER_ADMIN_SECRET_KEY=change-this-secret-key
